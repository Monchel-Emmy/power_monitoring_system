# Auth
# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/
# 1. Create project or select existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web Application)
# 4. Add: http://localhost:3000/auth-success (development)
# 5. Add: https://power-monitoring-system.vercel.app/auth-success (production)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Auth (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Optional: restrict CORS to your deployed frontend
FRONTEND_ORIGIN=https://power-monitoring-system.vercel.app

