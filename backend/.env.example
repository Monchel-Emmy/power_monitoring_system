# Server
PORT=4000

# MongoDB (Atlas or local)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/powermonitoring?retryWrites=true&w=majority

# Auth (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Optional: restrict CORS to your deployed frontend
FRONTEND_ORIGIN=https://your-app.vercel.app

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/
# 1. Create project or select existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web Application)
# 4. Add authorized redirect URIs for your frontend
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration
# Gmail example:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
